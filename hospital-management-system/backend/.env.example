# Copy to .env and adjust as needed.

SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database: set DB_ENGINE=mysql to use MySQL as specified in the project
# report; omit/leave as "sqlite" to run against a local SQLite file with
# zero extra setup (handy for grading/demoing the system).
DB_ENGINE=sqlite
DB_NAME=hms_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

TIME_ZONE=Africa/Lagos
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
